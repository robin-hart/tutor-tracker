# Local backend database configuration.
# Copy this file to .env in the repository root before starting the backend in development mode.
DB_URL=jdbc:mariadb://localhost:3306/tutortimetracker
DB_USERNAME=tutortime
DB_PASSWORD=tutortime

# Docker host port for the frontend nginx container.
# The container still listens on port 80 internally.
FRONTEND_HOST_PORT=8400
